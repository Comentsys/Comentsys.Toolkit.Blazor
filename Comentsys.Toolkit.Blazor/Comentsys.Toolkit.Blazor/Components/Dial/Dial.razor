@namespace Comentsys.Toolkit.Blazor
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 @Size @Size" width="@Size" height="@Size"
    @onpointerdown="StartCapture" @onpointermove="MoveKnob" 
    @onpointerup="EndCapture" @onpointerleave="EndCapture"
    style="user-select: none">
    @if (!string.IsNullOrWhiteSpace(Title))
    {
        <title>@Title</title>
    }
    <circle cx="@Radius" cy="@Radius" r="@Radius" fill="@_fill" />
    <rect x="@((Radius - Curve))" y="@((Radius - Radius))" 
    width="@KnobWidth" height="@Radius" fill="@_foreground" rx="@Curve" ry="@Curve" 
    transform="rotate(@Rotate, @Radius, @Radius)" />
</svg>